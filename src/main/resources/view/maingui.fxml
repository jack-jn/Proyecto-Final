<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="700.0"
            prefWidth="1200.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="pe.edu.upeu.controller.MainGuiController">

    <VBox prefWidth="220.0"
          prefHeight="700.0"
          style="-fx-background-color:#1E293B;">

        <children>

            <Label text="ENCOMIENDAS"
                   style="-fx-text-fill:white;
                          -fx-font-size:20px;
                          -fx-font-weight:bold;" />

            <Button text="Gestión Encomiendas"
                    onAction="#abrirEncomiendas"
                    prefWidth="200"/>

        </children>

    </VBox>

    <AnchorPane fx:id="contentPane"
                layoutX="220.0"
                prefHeight="700.0"
                prefWidth="980.0"/>

</AnchorPane>