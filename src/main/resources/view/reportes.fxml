<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="pe.edu.upeu.controller.ReportesController"
            style="-fx-background-color:#F8FAFC;">

    <children>

        <VBox spacing="15"
              layoutX="30"
              layoutY="30"
            style="-fx-background-color:white;
            -fx-background-radius:20;
            -fx-border-color:#059669;
            -fx-border-width:3;
            -fx-border-radius:20;
            -fx-padding:25;">

            <children>

                <Label text="📑 REPORTES DEL SISTEMA"
                       style="-fx-font-size:32px;
       -fx-font-weight:bold;
       -fx-text-fill:#059669;" />

                <Label text="Resumen general de encomiendas"
                       style="-fx-font-size:14px;" />

                <Label text="📦 Total de Encomiendas:" />
                <Label fx:id="lblTotal"
                       text="0"
                       style="-fx-font-size:22px;
                              -fx-font-weight:bold;" />

                <Label text="⏳ Pendientes:" />
                <Label fx:id="lblPendientes"
                       text="0"
                       style="-fx-font-size:22px;
                              -fx-font-weight:bold;" />

                <Label text="🚚 En Camino:" />
                <Label fx:id="lblEnCamino"
                       text="0"
                       style="-fx-font-size:22px;
                              -fx-font-weight:bold;" />

                <Label text="✅ Entregadas:" />
                <Label fx:id="lblEntregadas"
                       text="0"
                       style="-fx-font-size:22px;
                              -fx-font-weight:bold;" />

                <Label text="❌ Canceladas:" />
                <Label fx:id="lblCanceladas"
                       text="0"
                       style="-fx-font-size:22px;
                              -fx-font-weight:bold;" />

            </children>

        </VBox>

    </children>

</AnchorPane>
