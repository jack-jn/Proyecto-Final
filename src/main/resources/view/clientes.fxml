<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            style="-fx-background-color:#F8FAFC;">

    <children>

        <VBox spacing="15"
              layoutX="30"
              layoutY="30"
              style="-fx-background-color:white;
             -fx-background-radius:20;
             -fx-border-color:#2563EB;
             -fx-border-width:3;
             -fx-border-radius:20;
             -fx-padding:25;">

            <children>

                <Label text="👥 CLIENTES"
                       style="-fx-font-size:32px;
              -fx-font-weight:bold;
              -fx-text-fill:#2563EB;"/>

                <Label text="Módulo de gestión de clientes"
                       style="-fx-font-size:14px;" />

                <Label text="Funcionalidades disponibles próximamente:" />

                <Label text="✓ Registro de clientes"
                       style="-fx-background-color:#DBEAFE;
              -fx-padding:10;
              -fx-background-radius:10;
              -fx-font-size:15px;"/>

                <Label text="✓ Búsqueda de clientes"
                       style="-fx-background-color:#DBEAFE;
              -fx-padding:10;
              -fx-background-radius:10;
              -fx-font-size:15px;"/>

                <Label text="✓ Historial de envíos" style="-fx-background-color:#DBEAFE;
              -fx-padding:10;
              -fx-background-radius:10;
              -fx-font-size:15px;"/>

                <Label text="✓ Actualización de datos" style="-fx-background-color:#DBEAFE;
              -fx-padding:10;
              -fx-background-radius:10;
              -fx-font-size:15px;"/>

            </children>

        </VBox>

    </children>

</AnchorPane>